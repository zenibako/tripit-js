{
	"name": "@zenibako/tripit",
	"version": "0.2.0",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zenibako/tripit-js.git"
	},
	"bugs": {
		"url": "https://github.com/zenibako/tripit-js/issues"
	},
	"homepage": "https://github.com/zenibako/tripit-js#readme",
	"scripts": {
		"build:lib": "mkdir -p ./dist && bun build ./src/index.ts --outfile ./dist/index.js --target node",
		"build:worker": "mkdir -p ./dist && bun build ./src/index.ts --outfile ./dist/worker.js --target bun",
		"build:cli": "mkdir -p ./dist && bun build ./index.ts --outfile ./dist/tripit.js --target node --banner '#!/usr/bin/env node'",
		"build": "rm -rf ./dist && bun run build:lib && bun run build:cli",
		"prepublish": "bun run build"
	},
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./node": {
			"import": "./dist/node.js",
			"default": "./dist/node.js"
		},
		"./worker": {
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"bin": {
		"tripit": "dist/tripit.js"
	},
	"files": [
		"dist",
		"src"
	],
	"devDependencies": {
		"@types/bun": "latest",
		"@types/tough-cookie": "^4.0.5"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"commander": "^14.0.3"
	}
}