{
	"name": "tripit",
	"version": "0.1.7",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dvcrn/tripit.git"
	},
	"bugs": {
		"url": "https://github.com/dvcrn/tripit/issues"
	},
	"homepage": "https://github.com/dvcrn/tripit#readme",
	"scripts": {
		"build:lib": "mkdir -p ./dist && bun build ./src/index.ts --outfile ./dist/index.js --target node",
		"build:cli": "mkdir -p ./dist && bun build ./index.ts --outfile ./dist/tripit.js --target node --banner '#!/usr/bin/env node'",
		"build": "rm -rf ./dist && bun run build:lib && bun run build:cli",
		"prepublish": "bun run build"
	},
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"bin": {
		"tripit": "dist/tripit.js"
	},
	"files": [
		"dist"
	],
	"devDependencies": {
		"@types/bun": "latest",
		"@types/tough-cookie": "^4.0.5"
	},
	"peerDependencies": {
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"cheerio": "^1.2.0",
		"commander": "^14.0.3",
		"fetch-cookie": "^3.2.0",
		"node-fetch": "^3.3.2",
		"tough-cookie": "^6.0.0"
	}
}
